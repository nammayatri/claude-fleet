#!/usr/bin/env bash
set -eo pipefail

# Generic multi-stage pipeline runner for claude-fleet
# Reads a pipeline JSON config and runs stages sequentially,
# with tasks within each stage running in parallel.
#
# Usage: fleet-pipeline <pipeline.json>

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

if [[ $# -lt 1 ]]; then
    echo "Usage: fleet-pipeline <pipeline.json>"
    echo ""
    echo "Pipeline JSON format:"
    echo '  {"stages": [{"name": "Audit", "tasks": [{"file": "tasks.json", "max_parallel": 10}]}]}'
    exit 1
fi

PIPELINE_FILE="$1"

if [[ ! -f "$PIPELINE_FILE" ]]; then
    echo "Pipeline file not found: $PIPELINE_FILE"
    exit 1
fi

log() { echo "[$(date '+%H:%M:%S')] $*"; }

wait_for_batches() {
    local label="$1"
    shift
    local files=("$@")

    log "Waiting for $label to complete..."
    while true; do
        local total_remaining=0
        local total_done=0
        local total_failed=0
        local total_tasks=0

        for f in "${files[@]}"; do
            local r=$(jq '[.tasks[] | select(.status == "pending" or .status == "running")] | length' "$f")
            local d=$(jq '[.tasks[] | select(.status == "done")] | length' "$f")
            local fl=$(jq '[.tasks[] | select(.status == "failed")] | length' "$f")
            local t=$(jq '.tasks | length' "$f")
            total_remaining=$((total_remaining + r))
            total_done=$((total_done + d))
            total_failed=$((total_failed + fl))
            total_tasks=$((total_tasks + t))
        done

        log "$label: $total_done/$total_tasks done, $total_failed failed, $total_remaining remaining"

        if [[ $total_remaining -eq 0 ]]; then
            log "═══ $label COMPLETE — $total_done done, $total_failed failed ═══"
            return 0
        fi

        sleep 60
    done
}

STAGE_COUNT=$(jq '.stages | length' "$PIPELINE_FILE")

log "═══════════════════════════════════════════════════════"
log "═══ PIPELINE STARTED ($STAGE_COUNT stages) ═══"
log "═══════════════════════════════════════════════════════"
log ""

for (( s=0; s<STAGE_COUNT; s++ )); do
    STAGE_NAME=$(jq -r ".stages[$s].name" "$PIPELINE_FILE")
    TASK_COUNT=$(jq ".stages[$s].tasks | length" "$PIPELINE_FILE")

    log "═══ STAGE $((s+1)): $STAGE_NAME ($TASK_COUNT task files) ═══"

    PIDS=()
    FILES=()

    for (( t=0; t<TASK_COUNT; t++ )); do
        FILE=$(jq -r ".stages[$s].tasks[$t].file" "$PIPELINE_FILE")
        MAX_P=$(jq -r ".stages[$s].tasks[$t].max_parallel // 5" "$PIPELINE_FILE")

        if [[ ! -f "$FILE" ]]; then
            log "WARNING: Task file not found: $FILE — skipping"
            continue
        fi

        FILES+=("$FILE")
        log "Launching: $FILE (max_parallel=$MAX_P)"
        MAX_PARALLEL="$MAX_P" "$SCRIPT_DIR/fleet" "$FILE" &
        PIDS+=($!)
    done

    # Wait for all orchestrators in this stage
    wait_for_batches "STAGE $((s+1)): $STAGE_NAME" "${FILES[@]}"

    # Reap orchestrator processes
    for pid in "${PIDS[@]}"; do
        wait "$pid" 2>/dev/null || true
    done

    log ""
done

# Final summary
log "═══════════════════════════════════════════════════════"
log "═══ PIPELINE COMPLETE ═══"
log "═══════════════════════════════════════════════════════"
log ""

grand_done=0
grand_failed=0
grand_total=0

for (( s=0; s<STAGE_COUNT; s++ )); do
    TASK_COUNT=$(jq ".stages[$s].tasks | length" "$PIPELINE_FILE")
    for (( t=0; t<TASK_COUNT; t++ )); do
        FILE=$(jq -r ".stages[$s].tasks[$t].file" "$PIPELINE_FILE")
        [[ ! -f "$FILE" ]] && continue
        done_count=$(jq '[.tasks[] | select(.status == "done")] | length' "$FILE")
        fail_count=$(jq '[.tasks[] | select(.status == "failed")] | length' "$FILE")
        total=$(jq '.tasks | length' "$FILE")
        grand_done=$((grand_done + done_count))
        grand_failed=$((grand_failed + fail_count))
        grand_total=$((grand_total + total))
        log "  $FILE: $done_count/$total done, $fail_count failed"
    done
done

log ""
log "GRAND TOTAL: $grand_done/$grand_total done, $grand_failed failed"
